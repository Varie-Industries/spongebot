{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Pytest: Unit tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["tests/unit", "-v"],
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Smoke test",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tests/smoke_test.py",
      "console": "integratedTerminal",
      "justMyCode": false
    },
    {
      "name": "Demo session (for GIF)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/scripts/demo_session.py",
      "console": "integratedTerminal",
      "justMyCode": false
    }
  ]
}
